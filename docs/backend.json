
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user account.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Decision": {
      "title": "Decision",
      "description": "A user's habit input.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "rawText": { "type": "string" },
        "structuredInput": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "rawText"]
    },
    "Simulation": {
      "title": "Simulation",
      "description": "The result of a simulation run.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "decisionId": { "type": "string" },
        "results": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "decisionId", "results"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "User profile data."
    },
    "/decisions/{decisionId}": {
      "schema": "#/backend/entities/Decision",
      "description": "User habits."
    },
    "/simulations/{simulationId}": {
      "schema": "#/backend/entities/Simulation",
      "description": "Simulation results."
    }
  }
}
